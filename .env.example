# ─── Team USA Hometown Signals API — Environment Variables ───────────────────
# Copy this file to .env and fill in your values for local development.
# On Cloud Run, set these as Cloud Run environment variables or Secret Manager
# references — do NOT commit a filled-in .env file to source control.
#
# .env is used only in local dev via python-dotenv; Cloud Run uses ADC / env vars.

# ─── Gemini / Vertex AI ───────────────────────────────────────────────────────

# Option A: Vertex AI (recommended for Cloud Run — uses Application Default Creds)
# Set your GCP project ID. Gemini 3 Flash Preview uses Vertex AI's global endpoint.
GCP_PROJECT=your-gcp-project-id
VERTEX_LOCATION=global
GEMINI_MODEL=gemini-3-flash-preview

# Option B: google-generativeai SDK fallback (local dev / non-GCP deploy)
# Leave blank to use Vertex AI or the local template fallback.
GEMINI_API_KEY=

# ─── CORS ────────────────────────────────────────────────────────────────────

# Set to "true" only for hackathon / demo environments (allows all origins).
# Leave as "false" and configure CORS_ALLOWED_ORIGINS for production.
CORS_ALLOW_ALL_ORIGINS=true

# Comma-separated list of allowed origins (used when CORS_ALLOW_ALL_ORIGINS=false).
# Lovable previews, Vercel, Netlify, and local dev ports are pre-set in main.py.
# Add your specific frontend origin here if needed.
# CORS_ALLOWED_ORIGINS=https://your-app.lovable.app,http://localhost:3000

# ─── Logging ─────────────────────────────────────────────────────────────────

LOG_LEVEL=INFO

# ─── Server ──────────────────────────────────────────────────────────────────

# PORT is injected automatically by Cloud Run; only set this locally if needed.
# PORT=8080
